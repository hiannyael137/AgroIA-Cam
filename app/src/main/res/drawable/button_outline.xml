<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#152E1E"/>
            <stroke android:width="1.5dp" android:color="#34C768"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#0D2219"/>
            <stroke android:width="1.5dp" android:color="#27A855"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>