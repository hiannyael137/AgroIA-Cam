<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿 Monstera"
            android:textColor="#F4FFF7"
            android:textSize="34sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:padding="22dp"
            android:layout_marginTop="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado IA: Saludable"
                android:textColor="#F4FFF7"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Humedad actual: 65%"
                android:textColor="#4ADE80"
                android:textSize="16sp"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <Button
            android:id="@+id/btnPhoneAnalyze"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="📷 Analizar con Teléfono"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/button_green"
            android:stateListAnimator="@null"
            android:layout_marginTop="24dp"/>

        <Button
            android:id="@+id/btnEspAnalyze"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="📡 Tomar Foto con ESP32"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/button_dark"
            android:stateListAnimator="@null"
            android:layout_marginTop="14dp"/>

        <Button
            android:id="@+id/btnCare"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🪴 Registrar Actividad"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/button_outline"
            android:stateListAnimator="@null"
            android:layout_marginTop="14dp"/>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="📈 Ver Historial"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/button_outline"
            android:stateListAnimator="@null"
            android:layout_marginTop="14dp"/>

    </LinearLayout>

</ScrollView>