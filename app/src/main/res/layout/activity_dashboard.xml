<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="40dp">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="44dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- tvGreeting: referenciado en DashboardActivity.kt -->
                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hola, Usuario "
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/tvPlantName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monstera"
                    android:textColor="@color/text_primary"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saludable"
                android:textColor="@color/status_ok"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/badge_ok"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"/>

        </LinearLayout>

        <!-- ── CARD SENSORES ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:padding="22dp"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Último análisis IA"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvIaStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sin análisis aún"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/divider_soft"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <!-- Sensores: IDs que usa DashboardActivity.kt -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💧 Humedad del suelo"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>

                <!-- tvHumidity — nombre exacto que usa el .kt -->
                <TextView
                    android:id="@+id/tvHumidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/green_glow"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="☀️ Luz ambiente"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>

                <!-- tvLight — nombre exacto que usa el .kt -->
                <TextView
                    android:id="@+id/tvLight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/amber"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌱 Suelo"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"/>

                <!-- tvSoil — nombre exacto que usa el .kt -->
                <TextView
                    android:id="@+id/tvSoil"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ── BOTONES ── -->

        <Button
            android:id="@+id/btnPhoneAnalyze"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="22dp"
            android:text="  Analizar con Cámara"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/button_green"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnEspAnalyze"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text=" Foto con ESP32-CAM"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/button_dark"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnCare"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="Registrar Actividad"
            android:textAllCaps="false"
            android:textColor="@color/text_accent"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/button_outline"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:text="Ver Historial"
            android:textAllCaps="false"
            android:textColor="@color/text_accent"
            android:textStyle="bold"
            android:textSize="16sp"
            android:background="@drawable/button_outline"
            android:stateListAnimator="@null"/>

    </LinearLayout>
</ScrollView>