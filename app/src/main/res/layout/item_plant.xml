<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPlant"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    card_view:cardCornerRadius="22dp"
    card_view:cardElevation="6dp"
    card_view:cardBackgroundColor="#173328">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- NOMBRE -->

        <TextView
            android:id="@+id/tvPlantName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rosa Patio"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- ESTADO -->

        <TextView
            android:id="@+id/tvPlantStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Estado: Saludable"
            android:textColor="#A5D6A7"
            android:textSize="15sp"
            android:layout_marginTop="12dp" />

        <!-- HUMEDAD -->

        <TextView
            android:id="@+id/tvHumidity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Humedad: 65%"
            android:textColor="#E0E0E0"
            android:textSize="15sp"
            android:layout_marginTop="6dp" />

        <!-- ULTIMO RIEGO -->

        <TextView
            android:id="@+id/tvLastWater"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Último riego: Hace 2 días"
            android:textColor="#BDBDBD"
            android:textSize="14sp"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>