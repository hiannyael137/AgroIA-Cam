<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="48dp"
            android:src="@drawable/agroia_logo"
            android:elevation="8dp"
            android:contentDescription="AgroIA Logo"/>

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crear Cuenta"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Regístrate para comenzar"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="36dp"/>

        <!-- Usuario -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Usuario" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/etUser"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/input_bg" android:hint="Nombre de usuario"
            android:paddingStart="18dp" android:paddingEnd="18dp"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:textSize="15sp" android:layout_marginBottom="18dp"/>

        <!-- Correo -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Correo electrónico" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/etEmail"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/input_bg" android:hint="tu@correo.com"
            android:inputType="textEmailAddress"
            android:paddingStart="18dp" android:paddingEnd="18dp"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:textSize="15sp" android:layout_marginBottom="18dp"/>

        <!-- Contraseña -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Contraseña" android:textColor="@color/text_secondary"
            android:textSize="13sp" android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/etPass"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:background="@drawable/input_bg" android:hint="Mínimo 8 caracteres"
            android:inputType="textPassword"
            android:paddingStart="18dp" android:paddingEnd="18dp"
            android:textColor="@color/text_primary" android:textColorHint="@color/text_hint"
            android:textSize="15sp"/>

        <!-- Error -->
        <TextView android:id="@+id/tvError"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="" android:textColor="@color/status_err"
            android:textSize="13sp" android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <!-- Botón registrar -->
        <Button android:id="@+id/btnCreate"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="Registrarse"
            android:textAllCaps="false" android:textColor="@color/white"
            android:textStyle="bold" android:textSize="16sp"
            android:background="@drawable/button_green"
            android:stateListAnimator="@null"/>

        <!-- Link a login -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="20dp"
            android:layout_marginBottom="40dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ya tengo cuenta  " android:textColor="@color/text_secondary"
                android:textSize="14sp"/>
            <TextView android:id="@+id/tvGoLogin"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Iniciar sesión" android:textColor="@color/text_accent"
                android:textSize="14sp" android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>