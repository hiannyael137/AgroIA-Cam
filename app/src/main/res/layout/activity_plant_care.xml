<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- HEADER -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Qué hiciste hoy?"
            android:textColor="#F4FFF7"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="18dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registra los cuidados de tus plantas y lleva un seguimiento saludable 🌱"
            android:textColor="#B7CBBE"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp" />

        <!-- CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:padding="20dp">

            <!-- PLANTA -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌿 Elige una planta"
                android:textColor="#F4FFF7"
                android:textStyle="bold"
                android:textSize="16sp" />

            <Spinner
                android:id="@+id/spinnerPlant"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="12dp" />

            <!-- ACTIVIDAD -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ ¿Qué actividad realizaste?"
                android:textColor="#F4FFF7"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="24dp" />

            <Spinner
                android:id="@+id/spinnerActivity"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="12dp" />

            <!-- NOTAS -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝 Cuéntanos un poco más"
                android:textColor="#F4FFF7"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="24dp" />

            <EditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/input_bg"
                android:gravity="top"
                android:hint="Ejemplo: La tierra estaba un poco seca..."
                android:inputType="textMultiLine"
                android:padding="16dp"
                android:textColor="#F4FFF7"
                android:textColorHint="#8FA79A" />

            <!-- BOTÓN -->

            <Button
                android:id="@+id/btnSaveActivity"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/button_green"
                android:stateListAnimator="@null"
                android:text="Guardar Registro 🌱"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>