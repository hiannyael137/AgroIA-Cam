<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_glass"
    android:padding="20dp"
    android:layout_marginTop="14dp">

    <!-- Fila superior: tipo resultado + badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvResultType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hongos leves detectados"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/tvPlantName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Planta: Monstera"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Badge de estado -->
        <TextView
            android:id="@+id/tvBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aviso"
            android:textColor="@color/status_warn"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/badge_warn"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"/>
    </LinearLayout>

    <!-- Separador -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@drawable/divider_soft" android:layout_marginBottom="12dp"/>

    <!-- Precisión -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Precisión IA"
            android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <TextView android:id="@+id/tvPrecision"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="92%" android:textColor="@color/green_glow"
            android:textStyle="bold" android:textSize="14sp"/>
    </LinearLayout>

    <!-- Barra de precisión -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="100"
        android:progress="92"
        android:layout_marginBottom="12dp"/>

    <!-- Método y fecha -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView android:id="@+id/tvMethod"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Método: ESP32-CAM"
            android:textColor="@color/text_secondary" android:textSize="12sp"/>
        <TextView android:id="@+id/tvDate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Hoy, 4:32 PM" android:textColor="@color/text_hint"
            android:textSize="12sp"/>
    </LinearLayout>

</LinearLayout>