<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_glass"
    android:padding="18dp"
    android:layout_marginTop="18dp">

    <!-- TIPO RESULTADO -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🦠 Hongos leves detectados"
        android:textColor="#F4FFF7"
        android:textStyle="bold"
        android:textSize="20sp" />

    <!-- PLANTA -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Planta: Monstera"
        android:textColor="#B7CBBE"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />

    <!-- PRECISIÓN -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Precisión IA: 92%"
        android:textColor="#4ADE80"
        android:textStyle="bold"
        android:textSize="14sp"
        android:layout_marginTop="6dp" />

    <!-- MÉTODO -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Método: ESP32-CAM"
        android:textColor="#B7CBBE"
        android:textSize="13sp"
        android:layout_marginTop="6dp" />

    <!-- FECHA -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hoy • 4:32 PM"
        android:textColor="#8FA79A"
        android:textSize="12sp"
        android:layout_marginTop="10dp" />

</LinearLayout>